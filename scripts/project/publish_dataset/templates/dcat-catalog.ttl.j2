##############################################################################
# Publishers / contact points

<{{ catalog_publisher.uri }}> a foaf:Agent;
    vcard:hasName "{{ catalog_publisher.name }}"@nl;
    vcard:hasEmail "{{ catalog_publisher.email }}" .

<{{ catalog_uri }}>
    a dcat:Catalog;
    mu:uuid "{{ catalog_uuid }}";
    dct:title "DECIDe DCAT catalog for {{ catalog_publisher.name }}"@en;
    dct:description "DCAT catalog for the DECIDe project for {{ catalog_publisher.name }}";
    dct:issued "{{ ISSUED }}"^^xsd:dateTime;
    dct:modified "{{ MODIFIED }}"^^xsd:dateTime;
    dct:language <http://publications.europa.eu/resource/authority/language/ENG>;
    foaf:homepage <https://www.vlaanderen.be/lokaal-bestuur/digitale-transformatie/slimme-lokale-databronnen/decide>;
    dct:publisher <{{ catalog_publisher.uri }}>;
    dcat:themeTaxonomy <https://vocab.belgif.be/auth/datatheme> .