@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix eli: <http://data.europa.eu/eli/ontology#> .
@prefix mu: <http://mu.semte.ch/vocabularies/core/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix epvoc: <https://data.europarl.europa.eu/def/epvoc#> .

<http://example.org/expression_1_shape>
    a sh:NodeShape ;
    sh:targetClass <http://data.europa.eu/eli/ontology#Expression> ;
    sh:prefixes [ sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://mu.semte.ch/vocabularies/core/"^^xsd:anyURI ;
        sh:prefix "mu" ;
    ] ], [ sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://data.europa.eu/eli/ontology#"^^xsd:anyURI ;
        sh:prefix "eli" ;
    ] ], [ sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://purl.org/dc/terms/"^^xsd:anyURI ;
        sh:prefix "dct" ;
    ] ], [ sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://www.w3.org/ns/org#"^^xsd:anyURI ;
        sh:prefix "org" ;
    ] ], [ sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "http://data.vlaanderen.be/ns/besluit#"^^xsd:anyURI ;
        sh:prefix "besluit" ;
    ] ], [ sh:declare [
        a sh:PrefixDeclaration ;
        sh:namespace "https://data.europarl.europa.eu/def/epvoc#"^^xsd:anyURI ;
        sh:prefix "epvoc" ;
    ] ];
    sh:property [
        sh:path mu:uuid ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:name "titel" ;
        sh:description "De titel van de expressie." ;
        sh:path eli:title ;
        sh:datatype rdf:langString ;
        sh:minCount 1 ;
    ] ;
    sh:property [
        sh:name "taal" ;
        sh:description "De taal van de expressie." ;
        sh:path eli:language ;
        sh:nodeKind sh:IRI;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:name "inhoud" ;
        sh:description "De inhoud van de expressie." ;
        sh:path epvoc:expressionContent ;
        sh:datatype rdf:langString ;
        sh:minCount 0 ;
    ] ;
    sh:property [
        sh:name "wordt weergegeven door" ;
        sh:path eli:is_embodied_by ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
    ] .