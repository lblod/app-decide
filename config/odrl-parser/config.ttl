ext:DctPeriodOfTimeAsset a odrl:Asset, sh:NodeShape ;
  odrl:partOf ext:decidePublicSlice ;
  sh:targetClass dct:PeriodOfTime .

ext:ElidlActivityAsset a odrl:Asset, sh:NodeShape ;
