    <http://data.europa.eu/eli/ontology#responsibility_of_agent>	<http://www.w3.org/2002/07/owl#versionInfo>	"created in v1.1"@en .
    <http://data.europa.eu/eli/eli-draft-legislation-ontology#documented_by_a_realization_of>	<http://purl.org/dc/elements/1.1/identifier>	"documented_by_a_realization_of" .
    <http://data.europa.eu/eli/ontology#has_annex>	<http://data.europa.eu/eli/ontology#specificPropertyOf>	<http://purl.org/dc/terms/relation> .
