    <http://www.example.org/id/.well-known/genid/vb10224>	<http://www.w3.org/2002/07/owl#unionOf>	<http://www.example.org/id/.well-known/genid/vb10228> .
    <http://www.example.org/id/.well-known/genid/vb10077>	<http://www.w3.org/1999/02/22-rdf-syntax-ns#first>	<http://data.europa.eu/eli/ontology#LegalExpression> .
    <http://data.europa.eu/eli/eli-draft-legislation-ontology#had_participation>	<http://purl.org/dc/elements/1.1/identifier>	"had_participation" .
    <http://data.europa.eu/eli/ontology#has_another_publication>	<http://www.w3.org/2000/01/rdf-schema#range>	<http://data.europa.eu/eli/ontology#LegalResource> .
